<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.DashboardController">
    
    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            
            <Label text="ChriOnline" styleClass="logo">
                <font>
                    <Font name="System Bold" size="24"/>
                </font>
            </Label>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Label fx:id="welcomeLabel" text="Welcome!"/>
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" styleClass="logout-button"/>
        </HBox>
    </top>
    
    <!-- Left Sidebar -->
    <left>
        <VBox spacing="10" styleClass="sidebar">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>
            
            <Label text="Menu" styleClass="sidebar-title">
                <font>
                    <Font name="System Bold" size="16"/>
                </font>
            </Label>
            
            <Button fx:id="productsButton" text="📦 Products" onAction="#showProducts" styleClass="menu-button" maxWidth="Infinity"/>
            <Button fx:id="cartButton" text="🛒 Shopping Cart" onAction="#showCart" styleClass="menu-button" maxWidth="Infinity"/>
            <Button fx:id="ordersButton" text="📋 My Orders" onAction="#showOrders" styleClass="menu-button" maxWidth="Infinity"/>
        </VBox>
    </left>
    
    <!-- Center Content Area -->
    <center>
        <VBox fx:id="contentArea" alignment="CENTER" spacing="20" styleClass="content-area">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>
            
            <Label text="Welcome to ChriOnline Dashboard" styleClass="content-title">
                <font>
                    <Font name="System Bold" size="28"/>
                </font>
            </Label>
            
            <Label text="Select an option from the menu to get started" styleClass="content-subtitle"/>
        </VBox>
    </center>
    
</BorderPane>
